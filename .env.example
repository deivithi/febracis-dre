# =========================================================
# FEBRACIS DRE | Variáveis de Ambiente
# =========================================================
# Copie para .env.local e preencha com suas credenciais.
# Produção canônica atual (Vercel deivithis-projects): https://vwxgrjjwbvdiaqxqbryk.supabase.co
VITE_APP_MODE=production
# production | demo | development — `demo` ativa a faixa de ambiente sintético na UI (definir também em Vercel → Settings → Environment Variables para builds de apresentação).

# U14 — sugestões inline por campo (ícone ao lado do valor monetário). `1` ou `true` para ativar; exige assistente habilitado no workspace.
# VITE_INLINE_ASSISTANT=
VITE_SUPABASE_URL=https://vwxgrjjwbvdiaqxqbryk.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Integração Node (testes RLS — não prefixar com VITE_ para não ir ao bundle; opcionalmente duplicar URL/anon aqui)
# SUPABASE_URL=...
# SUPABASE_ANON_KEY=...
# SUPABASE_SERVICE_ROLE_KEY=service-role-key-test-env-only

# API do assistente (Vercel / servidor — não expor no bundle VITE_*)
# Prioridade: se OPENAI_API_KEY estiver definida, usa API OpenAI nativa; senão OPENROUTER_API_KEY.
# Sem nenhuma das duas, o assistente usa modo guiado local (fallback).
OPENAI_API_KEY=
# Configuração segura (atualiza .env.local + Vercel Production): npm run configure:openai
OPENAI_MODEL=gpt-5.4-mini
OPENROUTER_API_KEY=
OPENROUTER_MODEL=minimax/minimax-m2.7
OPENROUTER_APP_URL=https://febracis-dre.vercel.app

# Rate limit do assistente (POST /api/dre-agent). Usa a RPC public.fn_agent_rate_check (migration 015).
# Aplicar migration no Supabase remoto; AGENT_RATE_LIMIT_ENABLED=false desliga o gate.
# AGENT_RATE_LIMIT_FAIL_CLOSED=true: se a RPC devolver payload inválido, trata como bloqueado (produção antes de demo A2).
AGENT_RATE_LIMIT_ENABLED=true
AGENT_RATE_LIMIT_PER_MINUTE=30
AGENT_RATE_LIMIT_WINDOW_SECONDS=60
AGENT_RATE_LIMIT_FAIL_CLOSED=false

# Edge Function admin-provision-user (Supabase): origens do portal autorizadas a CORS (lista separada por vírgulas).
# Definir também em Supabase Dashboard → Edge Functions → Secrets para produção.
# Ex.: https://febracis-dre.vercel.app,http://localhost:5173
ADMIN_PROVISION_ALLOWED_ORIGINS=

# Outbox transacional (migration 017) — relay GET/POST /api/outbox-dispatcher
# Vercel Cron envia Authorization: Bearer ${CRON_SECRET} quando CRON_SECRET está definido.
CRON_SECRET=
OUTBOX_DISPATCHER_CRON_SECRET=
# Opcional: webhook n8n/agregador. Sem URL, o dispatcher regista JSON em log (modo log_only).
OUTBOX_WEBHOOK_URL=
# Obrigatório no servidor para claim/complete RPC (nunca VITE_*).
SUPABASE_SERVICE_ROLE_KEY=

# --- Geração local de favicons (npm run favicons) — opcional; não é usado em runtime na Vercel
# Aba (16/32): transparente por defeito. Sólido opcional: FAVICON_TAB_BG_HEX=#RRGGBB
# Legado: FAVICON_TRANSPARENT=1 força aba transparente e ignora FAVICON_TAB_BG_HEX
# Apple-touch (180): defeito #FBF6EC. Override: FAVICON_APPLE_BG_HEX ou FAVICON_BG_HEX
# Apple transparente: FAVICON_APPLE_TRANSPARENT=1
# FAVICON_TAB_BG_HEX=
# FAVICON_TRANSPARENT=
# FAVICON_APPLE_BG_HEX=
# FAVICON_BG_HEX=
# FAVICON_APPLE_TRANSPARENT=

# ---------- Assistente DRE — flags servidor (Node / Vercel; sem VITE_* ) ----------
# Valores aceites: 1 | true | yes | on (case-insensitive via api/agentFeatureFlags.ts)
# DRE_AGENT_CONTEXT_V2=
# DRE_AGENT_HISTORY_CONTEXT=
# DRE_AGENT_PERSONA_MEMORY=
# DRE_AGENT_IDEAL_STATE=
# DRE_AGENT_VERIFY_LEARN=
# DRE_AGENT_BITTER_PROMPT=
# Opcional QA: obrigar gate local de evals live antes de cortar sobre.
# DRE_AGENT_LIVE_EVALS_REQUIRED=

# TTL opcional (dias UTC) para linhas em assistant_persona_memory e ISA — 0 ou ausente = sem expires_at aplicado pelo servidor.
# DRE_AGENT_PERSONA_TTL_DAYS=90
# DRE_AGENT_ISA_TTL_DAYS=180

# Eval HTTP opcional (Vitest) — ver tests/integration/README-dre-agent-live-evals.md
# DRE_AGENT_LIVE_EVAL=1
# DRE_AGENT_EVAL_JWT=
# DRE_AGENT_EVAL_SESSION_ID=
# DRE_AGENT_EVAL_SUBMISSION_ID=
# DRE_AGENT_EVAL_API_URL=https://febracis-dre.vercel.app/api/dre-agent

# Modelo OpenRouter: só alterar esta linha quando quiser mudar modelo (copiar slug do dashboard OpenRouter).
# OPENROUTER_MODEL=
