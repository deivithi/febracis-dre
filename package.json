{
  "name": "febracis-dre",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy:pages": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-gh-pages.ps1",
    "validate:settings": "node scripts/validate-access-settings.mjs",
    "validate:phase1": "node scripts/validate-dre-foundation.mjs",
    "validate:phase1:local": "node scripts/validate-dre-foundation.mjs --allow-local-only",
    "validate:phase1:apply-migration": "node scripts/validate-dre-foundation.mjs --apply-migration",
    "test:e2e": "playwright test",
    "test": "vitest run",
    "test:watch": "vitest",
    "favicons": "node scripts/generate-favicons.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@langchain/core": "^1.1.36",
    "@langchain/langgraph": "^1.2.6",
    "@langchain/openai": "^1.3.1",
    "@supabase/supabase-js": "^2.100.1",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-table": "^8.21.3",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.51.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "sharp": "^0.34.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^3.2.4"
  }
}
