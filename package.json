{
  "name": "febracis-dre",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "verify:dist": "node scripts/verify-dist-supabase.mjs",
    "verify:security-headers": "node scripts/verify-security-headers.mjs",
    "smoke:prod": "node scripts/smoke-prod-bundle.mjs",
    "smoke:staging": "node -e \"console.log('\\nSmoke staging (manual): tests/README-staging-smoke.md\\n');\"",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy:pages": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-gh-pages.ps1",
    "validate:settings": "node scripts/validate-access-settings.mjs",
    "validate:phase1": "node scripts/validate-dre-foundation.mjs",
    "validate:phase1:local": "node scripts/validate-dre-foundation.mjs --allow-local-only",
    "validate:phase1:apply-migration": "node scripts/validate-dre-foundation.mjs --apply-migration",
    "validate:migrations": "node scripts/validate-migration-pairs.mjs",
    "test:rollback:local": "node scripts/test-rollback-local.mjs",
    "test:db-rollback": "node scripts/test-rollback-local.mjs",
    "test:e2e": "playwright test",
    "screenshot:guide": "node scripts/screenshot-guide.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:engine": "vitest run tests/unit/dre-engine-golden.test.ts",
    "test:rls": "vitest run tests/integration/rls-personas.test.ts",
    "test:watch": "vitest",
    "favicons": "node scripts/generate-favicons.mjs",
    "configure:openai": "powershell -ExecutionPolicy Bypass -File ./scripts/configure-openai-api-key.ps1"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.5",
    "@fontsource/jetbrains-mono": "^5.2.5",
    "@fontsource/sora": "^5.2.5",
    "@hookform/resolvers": "^5.2.2",
    "@langchain/core": "^1.1.36",
    "@langchain/langgraph": "^1.2.6",
    "@langchain/openai": "^1.3.1",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-pdf/renderer": "^4.5.1",
    "@supabase/supabase-js": "^2.100.1",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.12",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "diff": "^7.0.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "next-themes": "^0.4.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-grid-layout": "^1.5.2",
    "react-hook-form": "^7.72.0",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.1",
    "shepherd.js": "^15.2.2",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.51.0",
    "@types/diff": "^7.0.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-grid-layout": "^1.3.6",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "playwright": "^1.51.0",
    "sharp": "^0.34.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^3.2.4"
  }
}
